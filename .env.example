# ============================================================
# DataRecharge Environment Configuration
# Copy this file as .env and fill in your actual values
# ============================================================

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=datarecharge
DB_USER=root
DB_PASS=

# aspget API (legacy verification services)
ASPGET_API_KEY=your_aspget_api_key
ASPGET_BVN_URL=https://api.aspget.com/bvn/
ASPGET_PNV_URL=https://api.aspget.com/pnv/
ASPGET_CAC_URL=https://api.aspget.com/cac/
ASPGET_PASSPORT_URL=https://api.aspget.com/passport/
ASPGET_DL_URL=https://api.aspget.com/drivers-license/
ASPGET_VIN_URL=https://api.aspget.com/vin/
